{
  "name": "forkmind",
  "version": "0.1.0",
  "description": "Local-first LLM state branching and debugging tool. Treat AI context windows like a Git repo.",
  "main": "src/sdk/index.js",
  "exports": {
    ".": "./src/sdk/index.js",
    "./langchain": "./src/integrations/langchain.js",
    "./vercel": "./src/integrations/vercel.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "forkmind": "bin/forkmind.js",
    "forkmind-mcp": "bin/forkmind-mcp.js"
  },
  "files": [
    "bin",
    "src",
    "scripts",
    "dashboard/dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "workspaces": [
    "dashboard"
  ],
  "scripts": {
    "start": "node bin/forkmind.js start",
    "init": "node bin/forkmind.js init",
    "dashboard:dev": "npm --workspace dashboard run dev",
    "dashboard:build": "npm --workspace dashboard run build",
    "test": "jest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepare": "node scripts/prepare.js",
    "prepack": "npm run dashboard:build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "llm",
    "openai",
    "anthropic",
    "ollama",
    "debugging",
    "proxy",
    "branching",
    "dag",
    "observability",
    "local-first",
    "llm-observability",
    "prompt-engineering",
    "ai-agents",
    "mcp",
    "model-context-protocol",
    "llm-debugging",
    "regression-testing",
    "context-window"
  ],
  "author": "Medhovarsh Bayyapureddi",
  "license": "MIT",
  "homepage": "https://medhovarsh.github.io/forkmind/",
  "repository": {
    "type": "git",
    "url": "https://github.com/medhovarsh/forkmind"
  },
  "bugs": {
    "url": "https://github.com/medhovarsh/forkmind/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.7.7",
    "commander": "^12.1.0",
    "express": "^4.21.0",
    "fs-extra": "^11.2.0",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "openai": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": true
    }
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.37.5",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0"
  }
}
