{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-09-29/server.schema.json",
  "name": "io.github.Medhovarsh/forkmind",
  "description": "Branchable LLM history DAG + encrypted context capsules agents can save, restore, and crypto-shred.",
  "repository": {
    "url": "https://github.com/Medhovarsh/forkmind",
    "source": "github"
  },
  "version": "0.4.1",
  "websiteUrl": "https://medhovarsh.github.io/forkmind/",
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "forkmind",
      "version": "0.4.1",
      "transport": {
        "type": "stdio"
      },
      "runtimeHint": "npx",
      "runtimeArguments": [
        {
          "type": "positional",
          "value": "mcp",
          "description": "start the stdio MCP server"
        }
      ]
    }
  ]
}
