{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-09-29/server.schema.json",
  "name": "io.github.medhovarsh/forkmind",
  "description": "LLM history DAG + encrypted context capsules: agents recall their own past turns and offload context into immutable, restorable, crypto-shreddable snapshots. Local-first.",
  "repository": {
    "url": "https://github.com/Medhovarsh/forkmind",
    "source": "github"
  },
  "version": "0.3.2",
  "websiteUrl": "https://medhovarsh.github.io/forkmind/",
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "forkmind",
      "version": "0.3.2",
      "transport": {
        "type": "stdio"
      },
      "runtimeHint": "npx",
      "runtimeArguments": [
        {
          "type": "positional",
          "value": "mcp",
          "description": "start the stdio MCP server"
        }
      ]
    }
  ]
}
